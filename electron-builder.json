{
  "appId": "com.termy.app",
  "productName": "Termy",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*"
  ],
  "asarUnpack": [
    "**/node_modules/@lydell/node-pty/**",
    "**/node_modules/node-pty/**"
  ],
  "win": {
    "target": "nsis"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "electronDownload": {
    "version": "41.2.0"
  }
}
